FROM node:20-alpine

WORKDIR /app

ENV NODE_ENV=development
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
ENV CHOKIDAR_USEPOLLING=1
ENV WATCHPACK_POLLING=true

EXPOSE 3000

CMD ["sh", "-lc", "corepack enable && if [ ! -d node_modules/.pnpm ]; then pnpm install --no-frozen-lockfile --ignore-scripts; fi && pnpm exec prisma generate && pnpm run build:icons && pnpm dev --hostname 0.0.0.0 --port 3000"]
